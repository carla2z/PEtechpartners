---
const currentYear = new Date().getFullYear();

const footerLinks = {
  services: [
    { href: '/solutions/system-integration', label: 'System Integration' },
    { href: '/solutions/workflow-automation', label: 'Workflow Automation' },
    { href: '/solutions/pipeline-management', label: 'Pipeline Management' },
    { href: '/solutions/data-security', label: 'Data Security' },
  ],
  resources: [
    { href: '/blog', label: 'Blog' },
    { href: '/tools', label: 'Free Tools' },
    { href: '/tools/software-waste-calculator', label: 'Software Waste Calculator' },
    { href: '/tools/firepower-estimator', label: 'Firepower Estimator' },
  ],
  company: [
    { href: '/process', label: 'Our Process' },
    { href: '/challenges', label: 'Challenges' },
    { href: '/contact', label: 'Contact' },
  ],
};
---

<footer class="bg-navy-950 text-zinc-300">
  <div class="h-px bg-gradient-to-r from-transparent via-gold-400 to-transparent"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-2.5 mb-4">
          <span aria-hidden="true" class="inline-flex items-center justify-center h-8 w-8 rounded-md text-white font-bold text-xs tracking-tight" style="background: linear-gradient(135deg, #BF0A30 0%, #800621 100%); box-shadow: rgba(0,0,0,0.15) 0px 0px 0px 1px;">PE</span>
          <span class="text-lg font-medium tracking-tight text-white">
            PE Tech Partners
          </span>
        </div>
        <p class="text-sm text-zinc-400 leading-relaxed max-w-xs mb-6">
          Technology alignment for private equity and M&A firms. We make your tools work together so your team can close faster.
        </p>
        <div class="space-y-1.5 text-sm">
          <p>2125 Albany Post Rd Suite 106</p>
          <p>Montrose, NY 10548</p>
          <a href="tel:+19177157100" class="text-crimson-300 hover:text-crimson-200 transition-colors">
            (917) 715-7100
          </a>
        </div>
      </div>

      <!-- Solutions -->
      <div>
        <h4 class="text-sm font-semibold text-gold-400 uppercase tracking-wider mb-4">Solutions</h4>
        <ul class="space-y-2.5">
          {footerLinks.services.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-zinc-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="text-sm font-semibold text-gold-400 uppercase tracking-wider mb-4">Resources</h4>
        <ul class="space-y-2.5">
          {footerLinks.resources.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-zinc-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-sm font-semibold text-gold-400 uppercase tracking-wider mb-4">Company</h4>
        <ul class="space-y-2.5">
          {footerLinks.company.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-zinc-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <div class="mt-8">
          <a
            href="/contact"
            class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-medium text-white bg-crimson-500 rounded-md tracking-tight hover:bg-crimson-600 active:scale-[0.98] transition-all shadow-[rgba(191,10,48,0.25)_0px_6px_20px_0px]"
          >
            Secure a Strategic Debrief
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-zinc-500">
        &copy; {currentYear} PE Tech Partners. All rights reserved.
      </p>
      <div class="flex items-center gap-6">
        <a href="/terms" class="text-xs text-zinc-500 hover:text-zinc-300 transition-colors">Terms of Service</a>
        <a href="/privacy" class="text-xs text-zinc-500 hover:text-zinc-300 transition-colors">Privacy Policy</a>
        <a
          href="https://www.linkedin.com/company/petech-partners"
          target="_blank"
          rel="noopener"
          aria-label="PE Tech Partners on LinkedIn"
          class="text-zinc-500 hover:text-white transition-colors inline-flex items-center gap-1.5 text-xs"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</footer>
