---
import MobileNav from './MobileNav';

const navLinks = [
  { href: '/challenges', label: 'Challenges' },
  { href: '/solutions', label: 'Solutions' },
  { href: '/process', label: 'Our Process' },
  { href: '/tools', label: 'Free Tools' },
  { href: '/blog', label: 'Blog' },
];
---

<header class="sticky top-0 z-40 w-full border-b border-navy-800/5 bg-[#FAFAF5]/90 backdrop-blur-xl">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <a href="/" class="flex items-center gap-2.5">
        <img src="/images/logo.png" alt="PE Tech Partners" class="h-9 w-auto" />
        <span class="text-lg font-semibold tracking-tight text-navy-800">
          PE Tech Partners
        </span>
      </a>

      <nav class="hidden lg:flex items-center gap-7">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm text-zinc-600 hover:text-navy-800 transition-colors relative after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-0 after:bg-crimson-500 after:transition-all hover:after:w-full"
          >
            {link.label}
          </a>
        ))}
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-medium text-white bg-crimson-500 rounded-lg hover:bg-crimson-600 active:scale-[0.98] transition-all shadow-[0_2px_12px_rgba(191,10,48,0.2)]"
        >
          Secure a Strategic Debrief
        </a>
      </nav>

      <MobileNav client:load navLinks={navLinks} />
    </div>
  </div>
</header>
