---
/**
 * NYCSkyline.astro
 *
 * Stylized night-time Manhattan skyline — renders as an absolute
 * background layer behind the hero copy. Pure inline SVG + CSS
 * keyframes; no JS. Respects prefers-reduced-motion.
 *
 * Layers (back to front):
 *   1. Star field (40 pulsing dots high in the sky)
 *   2. Distant buildings (silhouette only, very dark)
 *   3. Foreground buildings with lit, twinkling windows
 *   4. Top gradient mask so skyline dissolves into the hero sky
 */

/* ------------------------------------------------------------------ */
/* Building geometry — iconic Manhattan silhouette across 1600x400.   */
/* Each building: x, width, height; topStyle encodes distinctive cap; */
/* windowCols/Rows + litDensity drive the window grid.                */
/* ------------------------------------------------------------------ */

type TopStyle = 'flat' | 'spire' | 'mast' | 'crown' | 'stepped' | 'tapered';

type Building = {
  x: number;
  w: number;
  h: number;
  top: TopStyle;
  cols: number;
  rows: number;
  density: number; // 0..1 fraction of windows lit
  crimsonChance: number; // 0..1 chance a lit window is crimson
};

const BASE_Y = 400; // bottom of SVG viewBox

const FOREGROUND: Building[] = [
  // One WTC — tapered spire (far left)
  { x:  20, w: 86,  h: 360, top: 'spire',   cols: 5, rows: 22, density: 0.38, crimsonChance: 0.04 },
  // narrow tower
  { x: 120, w: 62,  h: 250, top: 'flat',    cols: 4, rows: 16, density: 0.30, crimsonChance: 0.02 },
  // stepped mid-rise
  { x: 190, w: 96,  h: 210, top: 'stepped', cols: 6, rows: 14, density: 0.46, crimsonChance: 0.05 },
  // Chrysler-style crown
  { x: 300, w: 84,  h: 300, top: 'crown',   cols: 5, rows: 18, density: 0.42, crimsonChance: 0.06 },
  // compact tall block
  { x: 398, w: 70,  h: 230, top: 'flat',    cols: 4, rows: 16, density: 0.34, crimsonChance: 0.03 },
  // Empire State with mast
  { x: 480, w: 110, h: 348, top: 'mast',    cols: 7, rows: 22, density: 0.44, crimsonChance: 0.05 },
  // short square
  { x: 604, w: 72,  h: 180, top: 'flat',    cols: 4, rows: 12, density: 0.38, crimsonChance: 0.03 },
  // 432 Park slab
  { x: 690, w: 54,  h: 328, top: 'flat',    cols: 3, rows: 22, density: 0.36, crimsonChance: 0.04 },
  // tapered tower
  { x: 756, w: 88,  h: 256, top: 'tapered', cols: 5, rows: 17, density: 0.40, crimsonChance: 0.04 },
  // wider crown
  { x: 858, w: 104, h: 288, top: 'crown',   cols: 6, rows: 19, density: 0.45, crimsonChance: 0.05 },
  // spire block
  { x: 976, w: 78,  h: 232, top: 'spire',   cols: 5, rows: 15, density: 0.38, crimsonChance: 0.03 },
  // stepped
  { x: 1068, w: 96, h: 266, top: 'stepped', cols: 6, rows: 18, density: 0.44, crimsonChance: 0.05 },
  // mid tower
  { x: 1178, w: 74, h: 208, top: 'flat',    cols: 4, rows: 14, density: 0.34, crimsonChance: 0.03 },
  // tall narrow
  { x: 1266, w: 58, h: 278, top: 'flat',    cols: 3, rows: 18, density: 0.36, crimsonChance: 0.04 },
  // Steinway-slim
  { x: 1338, w: 48, h: 310, top: 'tapered', cols: 3, rows: 20, density: 0.40, crimsonChance: 0.05 },
  // short block
  { x: 1400, w: 72, h: 170, top: 'flat',    cols: 4, rows: 11, density: 0.30, crimsonChance: 0.02 },
  // last tall tower with mast
  { x: 1486, w: 86, h: 260, top: 'mast',    cols: 5, rows: 17, density: 0.38, crimsonChance: 0.04 },
];

/* Distant silhouette layer — simpler + shorter */
const DISTANT: { x: number; w: number; h: number }[] = [
  {x:   0, w:  64, h: 100}, {x:  66, w:  48, h: 150}, {x: 118, w:  72, h: 120},
  {x: 194, w:  54, h: 170}, {x: 252, w:  80, h: 135}, {x: 336, w:  62, h: 195},
  {x: 402, w:  48, h: 125}, {x: 454, w:  68, h: 170}, {x: 526, w:  56, h: 140},
  {x: 586, w:  74, h: 190}, {x: 664, w:  50, h: 120}, {x: 718, w:  66, h: 160},
  {x: 788, w:  58, h: 205}, {x: 850, w:  72, h: 138}, {x: 926, w:  54, h: 170},
  {x: 984, w:  68, h: 148}, {x:1056, w:  60, h: 185}, {x:1120, w:  78, h: 130},
  {x:1202, w:  52, h: 160}, {x:1258, w:  70, h: 200}, {x:1332, w:  58, h: 128},
  {x:1394, w:  80, h: 172}, {x:1478, w:  54, h: 148}, {x:1536, w:  64, h: 180},
];

/* ------------------------------------------------------------------ */
/* Deterministic pseudo-random so SSR + hydration agree (no flicker). */
/* ------------------------------------------------------------------ */
function mulberry32(seed: number) {
  return function () {
    seed |= 0;
    seed = (seed + 0x6d2b79f5) | 0;
    let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
const rand = mulberry32(20260415);

/* Pre-compute windows per foreground building */
type Win = { x: number; y: number; w: number; h: number; lit: boolean; crimson: boolean; delay: number };
const windowsPerBuilding: Win[][] = FOREGROUND.map((b) => {
  // leave margin around building edges; account for top cap style
  const padX = 4;
  const topMargin =
    b.top === 'spire' || b.top === 'mast' ? 36 :
    b.top === 'crown' ? 24 :
    b.top === 'stepped' ? 20 :
    b.top === 'tapered' ? 28 :
    10;
  const winAreaW = b.w - padX * 2;
  const winAreaH = b.h - topMargin - 10;
  const gapX = 3, gapY = 3;
  const cellW = (winAreaW - gapX * (b.cols - 1)) / b.cols;
  const cellH = (winAreaH - gapY * (b.rows - 1)) / b.rows;
  const topY = BASE_Y - b.h + topMargin;
  const wins: Win[] = [];
  for (let row = 0; row < b.rows; row++) {
    for (let col = 0; col < b.cols; col++) {
      const wx = b.x + padX + col * (cellW + gapX);
      const wy = topY + row * (cellH + gapY);
      const lit = rand() < b.density;
      const crimson = lit && rand() < b.crimsonChance;
      const delay = rand() * 7; // 0..7s stagger
      wins.push({ x: wx, y: wy, w: cellW, h: cellH, lit, crimson, delay });
    }
  }
  return wins;
});

/* Stars */
const STARS = Array.from({ length: 48 }, () => ({
  left: rand() * 100,
  top: rand() * 55,
  size: 1 + Math.floor(rand() * 2),
  delay: rand() * 5,
  duration: 2.5 + rand() * 3,
}));

/* Helper: build top path for each style; returns SVG <path d=...> string */
function topPath(b: Building): string {
  const { x, w, h, top } = b;
  const baseY = BASE_Y;
  const topY = baseY - h;
  const mid = x + w / 2;
  switch (top) {
    case 'spire':
      // rectangle body + thin spire on top
      return `M ${x} ${baseY} L ${x} ${topY + 30} L ${mid - 3} ${topY + 30} L ${mid - 1} ${topY - 22} L ${mid + 1} ${topY - 22} L ${mid + 3} ${topY + 30} L ${x + w} ${topY + 30} L ${x + w} ${baseY} Z`;
    case 'mast':
      // rectangle + broader mast
      return `M ${x} ${baseY} L ${x} ${topY + 26} L ${mid - 6} ${topY + 26} L ${mid - 4} ${topY - 4} L ${mid - 2} ${topY - 30} L ${mid + 2} ${topY - 30} L ${mid + 4} ${topY - 4} L ${mid + 6} ${topY + 26} L ${x + w} ${topY + 26} L ${x + w} ${baseY} Z`;
    case 'crown':
      // art-deco stepped crown
      return `M ${x} ${baseY} L ${x} ${topY + 16} L ${x + 6} ${topY + 16} L ${x + 6} ${topY + 6} L ${x + w - 6} ${topY + 6} L ${x + w - 6} ${topY + 16} L ${x + w} ${topY + 16} L ${x + w} ${baseY} Z M ${mid - 6} ${topY + 6} L ${mid - 4} ${topY - 14} L ${mid + 4} ${topY - 14} L ${mid + 6} ${topY + 6} Z`;
    case 'stepped':
      // single setback near top
      return `M ${x} ${baseY} L ${x} ${topY + 12} L ${x + 8} ${topY + 12} L ${x + 8} ${topY} L ${x + w - 8} ${topY} L ${x + w - 8} ${topY + 12} L ${x + w} ${topY + 12} L ${x + w} ${baseY} Z`;
    case 'tapered':
      // slight inward taper at top
      return `M ${x} ${baseY} L ${x} ${topY + 18} L ${x + 6} ${topY} L ${x + w - 6} ${topY} L ${x + w} ${topY + 18} L ${x + w} ${baseY} Z`;
    default: // flat
      return `M ${x} ${baseY} L ${x} ${topY} L ${x + w} ${topY} L ${x + w} ${baseY} Z`;
  }
}
---

<div class="nyc-skyline absolute inset-x-0 bottom-0 h-[70%] pointer-events-none select-none" aria-hidden="true">
  {/* star field */}
  <div class="absolute inset-0">
    {STARS.map((s) => (
      <span
        class="nyc-star"
        style={`left:${s.left}%;top:${s.top}%;width:${s.size}px;height:${s.size}px;animation-delay:${s.delay}s;animation-duration:${s.duration}s;`}
      />
    ))}
  </div>

  {/* distant silhouette */}
  <svg
    class="absolute bottom-0 left-0 w-full h-auto"
    viewBox="0 0 1600 280"
    preserveAspectRatio="xMidYEnd slice"
  >
    <g fill="#020812" opacity="0.55">
      {DISTANT.map((d) => (
        <rect x={d.x} y={280 - d.h} width={d.w} height={d.h} />
      ))}
    </g>
  </svg>

  {/* foreground skyline with twinkling windows */}
  <svg
    class="absolute bottom-0 left-0 w-full h-auto"
    viewBox="0 0 1600 400"
    preserveAspectRatio="xMidYEnd slice"
  >
    {FOREGROUND.map((b, i) => (
      <g>
        {/* building silhouette */}
        <path d={topPath(b)} fill="#050e1c" />
        {/* subtle rim highlight on upper edge */}
        <path d={topPath(b)} fill="none" stroke="rgba(197,165,114,0.12)" stroke-width="0.8" />
        {/* windows */}
        {windowsPerBuilding[i].filter((w) => w.lit).map((w) => (
          <rect
            x={w.x}
            y={w.y}
            width={w.w}
            height={w.h}
            class={w.crimson ? 'nyc-window nyc-window-crimson' : 'nyc-window'}
            style={`animation-delay:${w.delay}s`}
          />
        ))}
      </g>
    ))}
  </svg>

  {/* top gradient — skyline dissolves into the sky */}
  <div
    class="absolute inset-0"
    style="background: linear-gradient(to top, rgba(3,14,25,0) 0%, rgba(3,14,25,0.25) 45%, rgba(3,14,25,0.7) 80%, rgba(3,14,25,0.95) 100%);"
  />
</div>

<style>
  .nyc-skyline .nyc-star {
    position: absolute;
    background: #ffffff;
    border-radius: 9999px;
    opacity: 0.75;
    box-shadow: 0 0 2px rgba(255, 255, 255, 0.6);
    animation: nyc-star-pulse 3s ease-in-out infinite;
  }

  .nyc-skyline .nyc-window {
    fill: #FDC86B;           /* warm tungsten yellow */
    opacity: 0.88;
    animation: nyc-twinkle 4.5s ease-in-out infinite;
    will-change: opacity;
  }

  .nyc-skyline .nyc-window-crimson {
    fill: #E24A5E;           /* lit crimson / red — brand-adjacent */
    opacity: 0.85;
  }

  @keyframes nyc-twinkle {
    0%, 100% { opacity: 0.88; }
    38%      { opacity: 0.18; }
    46%      { opacity: 0.72; }
    60%      { opacity: 0.95; }
    78%      { opacity: 0.32; }
  }

  @keyframes nyc-star-pulse {
    0%, 100% { opacity: 0.35; transform: scale(1); }
    50%      { opacity: 1;    transform: scale(1.25); }
  }

  /* accessibility — honor reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .nyc-skyline .nyc-window,
    .nyc-skyline .nyc-star {
      animation: none;
    }
  }
</style>
